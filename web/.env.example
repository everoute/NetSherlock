# Environment Configuration Example
# Copy this file to .env.local and modify as needed for your local setup

# Backend API Configuration
# The address of the backend API server
VITE_API_URL=http://localhost:8000

# Use Mock Data
# Set to 'true' to use local mock data instead of calling the backend API
# Useful when the backend is not running or for frontend-only development
VITE_USE_MOCK_DATA=false

# Environment Type
# Usually 'development' or 'production'
VITE_ENVIRONMENT=development

# Examples for different scenarios:
# ========================================

# Scenario 1: Backend on different port (8001)
# VITE_API_URL=http://localhost:8001

# Scenario 2: Using mock data (no backend needed)
# VITE_USE_MOCK_DATA=true

# Scenario 3: Remote development backend
# VITE_API_URL=https://dev-api.example.com

# Scenario 4: Combination - remote backend + mock data
# VITE_API_URL=https://dev-api.example.com
# VITE_USE_MOCK_DATA=true
