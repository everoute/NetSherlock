# NetSherlock Configuration
# Copy this file to .env and modify as needed

# Application settings
DEBUG=false

# SSH Settings
SSH_DEFAULT_USER=root
SSH_DEFAULT_PORT=22
SSH_PRIVATE_KEY_PATH=~/.ssh/id_rsa
# SSH_PASSWORD=your_password_here
SSH_CONNECT_TIMEOUT=10
SSH_COMMAND_TIMEOUT=60
SSH_MAX_CONNECTIONS=10

# Grafana Settings
GRAFANA_BASE_URL=http://192.168.79.79/grafana
GRAFANA_USERNAME=o11y
GRAFANA_PASSWORD=HC!r0cks
GRAFANA_TIMEOUT=30

# BPF Tools Settings
BPF_LOCAL_TOOLS_PATH=~/workspace/troubleshooting-tools/measurement-tools
BPF_REMOTE_TOOLS_PATH=/tmp/netsherlock-tools
BPF_DEPLOY_MODE=auto  # auto, scp, or pre-deployed
BPF_REMOTE_PYTHON=/usr/bin/python3

# Logging Settings
LOG_LEVEL=INFO
LOG_FORMAT=console  # json or console
# LOG_FILE_PATH=/var/log/netsherlock/netsherlock.log

# Measurement Settings
MEASUREMENT_DEFAULT_DURATION=30
MEASUREMENT_RECEIVER_READY_TIMEOUT=10
MEASUREMENT_RECEIVER_STARTUP_DELAY=1.0
MEASUREMENT_MAX_CONCURRENT_MEASUREMENTS=5

# LLM Settings (Claude Agent SDK)
# ============================================================
# Authentication options (choose one):
#   1. Run `claude` command to login - SDK uses that auth automatically
#   2. Set ANTHROPIC_API_KEY (sk-ant-api03-xxx format)
#   3. Use cloud providers: CLAUDE_CODE_USE_BEDROCK=1 / VERTEX=1 / FOUNDRY=1
#
# NOTE: OpenRouter (sk-or-v1-xxx) is NOT supported
# ANTHROPIC_API_KEY=sk-ant-api03-your-key-here
#
# Model options (from cheapest to most capable):
#   - claude-haiku-4-5-20251001  (fastest, cheapest - RECOMMENDED)
#   - claude-sonnet-4-5-20250929 (balanced)
#   - claude-opus-4-5-20251101   (most capable, expensive)
# Aliases also work: claude-haiku-4-5, claude-sonnet-4-5, claude-opus-4-5
LLM_MODEL=claude-haiku-4-5-20251001
#
# Cost control (optional)
# LLM_MAX_TURNS=50           # Limit agent turns per skill invocation
# LLM_MAX_BUDGET_USD=1.0     # Limit cost per skill invocation

# Diagnosis Settings
DIAGNOSIS_DEFAULT_MODE=interactive  # autonomous or interactive
DIAGNOSIS_AUTONOMOUS_ENABLED=false
DIAGNOSIS_AUTONOMOUS_AUTO_AGENT_LOOP=false
DIAGNOSIS_INTERACTIVE_TIMEOUT_SECONDS=300
